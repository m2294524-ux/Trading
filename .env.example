# ============================================================
#  SMC Bot v4 — Environment Variables
#  Copy file ini jadi .env untuk run lokal,
#  atau isi langsung di Railway → Variables
# ============================================================

# Bybit API Key (wajib)
API_KEY=isi_api_key_kamu_di_sini

# Bybit API Secret (wajib)
API_SECRET=isi_api_secret_kamu_di_sini

# Testnet mode: true = pakai Bybit Testnet, false = live trading
# Default: false
TESTNET=false

# Port log server (Railway otomatis set ini, tidak perlu diubah)
# PORT=8080
